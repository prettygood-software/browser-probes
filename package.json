{
  "name": "@prettygood-software/browser-probes",
  "version": "0.1.1",
  "description": "Composable browser-diagnostic probes (CreepJS, GeoIP coherence) on top of @prettygood-software/site-runner. CLI + programmatic.",
  "type": "module",
  "bin": {
    "browser-probe": "./dist/cli.js"
  },
  "files": [
    "dist",
    "bin",
    "README.md"
  ],
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "restricted"
  },
  "prettier": "@prettygood-software/ts-config/prettier.json",
  "scripts": {
    "dev": "bun run src/cli.ts",
    "build": "bun build ./src/cli.ts --outdir ./dist --target bun --format esm --packages external",
    "build:binary": "bun build ./src/cli.ts --compile --outfile ./dist/browser-probe",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "spell": "cspell --no-progress \"**/*.{ts,md,json}\"",
    "check": "bun run typecheck && bun run lint && bun run format:check && bun run spell && bun run test"
  },
  "dependencies": {
    "@prettygood-software/site-runner": "^1.4.0",
    "citty": "^0.1.6",
    "dotenv": "^16.0.0",
    "playwright-core": "1.59.1",
    "pino": "^10",
    "pino-pretty": "^11"
  },
  "devDependencies": {
    "@prettygood-software/ts-config": "^0.3.0",
    "@types/bun": "latest",
    "@types/node": "^22",
    "typescript": "^5.7",
    "typescript-eslint": "^8",
    "eslint": "^9",
    "prettier": "^3",
    "cspell": "^8"
  },
  "engines": {
    "bun": ">=1.1"
  }
}
