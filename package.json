{
  "name": "@prettygood-software/ts-cli-template",
  "version": "0.0.0",
  "description": "TypeScript CLI template with citty, pino, i18n, and modern tooling",
  "type": "module",
  "private": true,
  "bin": {
    "hello-cli": "./dist/cli.js"
  },
  "prettier": "@prettygood-software/ts-config/prettier.json",
  "scripts": {
    "dev": "bun run src/cli.ts",
    "build": "bun build ./src/cli.ts --outdir ./dist --target bun --format esm --banner '#!/usr/bin/env bun'",
    "build:binary": "bun build ./src/cli.ts --compile --outfile ./dist/hello-cli",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "spell": "cspell --no-progress \"**/*.{ts,md,json}\"",
    "check": "bun run typecheck && bun run lint && bun run format:check && bun run spell && bun run test"
  },
  "dependencies": {
    "citty": "^0.1.6",
    "pino": "^9",
    "pino-pretty": "^11"
  },
  "devDependencies": {
    "@prettygood-software/ts-config": "^0.3.0",
    "@types/bun": "latest",
    "@types/node": "^22",
    "typescript": "^5.7",
    "typescript-eslint": "^8",
    "eslint": "^9",
    "prettier": "^3",
    "cspell": "^8"
  },
  "engines": {
    "bun": ">=1.1"
  }
}
